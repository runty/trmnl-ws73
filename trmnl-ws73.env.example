TRMNL_BASE_URL=https://usetrmnl.com
TRMNL_API_KEY=replace-me
TRMNL_MAC=replace-me

# Optional tuning
TRMNL_MODEL=Waveshare 7.3 Spectra 6
TRMNL_WIDTH=800
TRMNL_HEIGHT=480
TRMNL_RUN_TIMEOUT=780s
TRMNL_DISPLAY_TIMEOUT=600
TRMNL_DISPLAY_CLEANUP_TIMEOUT=30
TRMNL_HTTP_TOTAL_TIMEOUT=120
TRMNL_HTTP_ATTEMPTS=3
TRMNL_HTTP_RETRY_DELAY=5
WAVESHARE_LIB=$HOME/e-Paper/RaspberryPi_JetsonNano/python/lib
